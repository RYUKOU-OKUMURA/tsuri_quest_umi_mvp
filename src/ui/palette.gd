## ゲージの意味色を状態で取得（安全域=緑, 警戒=琥珀, 危険=赤）。
static func gauge_pair(level: String) -> Dictionary:
	match level:
		"amber":
			return {"from": GAUGE_AMBER, "to": GAUGE_AMBER_HI}
		"red":
			return {"from": GAUGE_RED, "to": GAUGE_RED_HI}
		_:
			return {"from": GAUGE_GREEN, "to": GAUGE_GREEN_HI}
